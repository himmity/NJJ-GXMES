<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LuminSDK</title>
    <style>
        body {
            background-color: #111;
            color: white;
            font-family: sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            margin: 0;
            padding: 20px;
        }
        h1 {
            font-style: italic;
            text-transform: uppercase;
        }
        .black { background: black; padding: 5px 10px; }
        .orange { background: #ff8c00; color: black; padding: 5px 10px; }
        
        #games {
            width: 100%;
            max-width: 900px;
            height: 600px;
            background: #222;
            border-radius: 8px;
            margin-top: 20px;
        }
        
        .footer-text {
            margin-top: 20px;
            font-size: 0.8rem;
            color: #666;
        }
    </style>
</head>
<body>


    <h1>
        <span class="black">NJJ</span><span class="orange">GXMES</span>
    </h1>


    <div id="games"></div>


    <p class="footer-text">Made by Virgo, but lumin was made by rah the femboy</p>


    <!-- Lumin SDK thingyaroo -->
    <script src="https://cdn.jsdelivr.net/gh/luminsdk/script@latest/lumin.min.js"></script>
    
    <script>
        // the thingy for skidding
        window.onload = function() {
            Lumin.init({
                container: '#games',
                theme: 'dark'
            });
        };
    </script>


</body>
</html>


